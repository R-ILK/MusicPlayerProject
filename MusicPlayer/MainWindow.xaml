<Window x:Class="MusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MusicPlayer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Button x:Name="btnRandom" Grid.Row="0" Grid.Column="0" Content="Random Track" 
                Background="Transparent" BorderThickness="0" 
                HorizontalAlignment="Left" Margin="0,0,0,10"
                FontSize="14" FontWeight="Bold" Cursor="Hand"/>

        <Button x:Name="btnAlbum" Grid.Row="0" Grid.Column="1" Content="Albums" 
                Background="Transparent" BorderThickness="0" 
                HorizontalAlignment="Left" Margin="0,0,0,10"
                FontSize="14" Cursor="Hand" Click="btnAlbum_Click" />

        <Button x:Name="btnPlaylists" Grid.Row="0" Grid.Column="2" Content="Playlists" 
                Background="Transparent" BorderThickness="0" 
                HorizontalAlignment="Left" Margin="0,0,0,10"
                FontSize="14" Cursor="Hand" Click="btnPlaylists_Click"/>


        <Grid x:Name="AlbumsView" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Albums" FontSize="20" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="1" Text="Name" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="2" Text="Author" FontSize="14" Foreground="Gray" Margin="0,0,0,15"/>

            <ListView x:Name="lstvAlbums" Background="Transparent" BorderThickness="0" Grid.Row="3">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="50">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Cover}" Width="60" Height="60"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="Title" Width="250" 
                            DisplayMemberBinding="{Binding Title}"/>

                        <GridViewColumn Header="Artist" Width="120" 
                            DisplayMemberBinding="{Binding Artist}"/>

                        <GridViewColumn Header="Duration" Width="70" 
                            DisplayMemberBinding="{Binding Length}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
        
        <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,10,0" x:Name="PlaylistsView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Playlist Name" FontSize="20" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="1" Text="Name" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="2" Text="Author" FontSize="14" Foreground="Gray" Margin="0,0,0,15"/>

            <ListView x:Name="lstvwPlaylist" Background="Transparent" BorderThickness="0" Grid.Row="3">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="50">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Cover}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="Title" Width="250" 
              DisplayMemberBinding="{Binding Title}"/>

                        <GridViewColumn Header="Artist" Width="120" 
              DisplayMemberBinding="{Binding Artist}"/>

                        <GridViewColumn Header="Duration" Width="70" 
              DisplayMemberBinding="{Binding Length}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="2" Background="#F5F5F5" Margin="10,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Now Playing" FontSize="16" FontWeight="Bold" Margin="10,10,10,5"/>
            <TextBlock Grid.Row="1" Text="Current Song" FontSize="14" FontWeight="SemiBold" Margin="10,0,10,5"/>
            <TextBlock Grid.Row="2" Text="Artist Name" FontSize="12" Foreground="Gray" Margin="10,0,10,15"/>

            <StackPanel Grid.Row="3" Margin="10">
                <TextBlock Text="Album Art" Foreground="Gray"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,20,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
        </Grid>

        <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,271,0">

                <Button Width="40" Height="40" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0">
                    <TextBlock Text="⏮" FontSize="24" Foreground="#333333"/>
                </Button>
                
                <Button x:Name="btnPlayStop" Width="50" Height="50" Background="Transparent" BorderThickness="0" 
                Cursor="Hand" Margin="0,0,10,0" Click="btnPlayStop_Click">
                    <TextBlock x:Name="PlayStopIcon" Text="▶" FontSize="35" Foreground="Gray"/>
                </Button>

                <Button Width="40" Height="40" Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock Text="⏭" FontSize="24" Foreground="#333333"/>
                </Button>

            </StackPanel>

            <Button Grid.Column="2" Content="Shuffle" Padding="15,8"  Foreground="White" Cursor="Hand"/>
        </Grid>
    </Grid>
</Window>
